    "    ws1.column_dimensions[get_column_letter(i)].width = w\n",
    "\n",
    "ws1.freeze_panes = 'A2'\n",
    "ws1.auto_filter.ref = f\"A1:F{len(df)+1}\"\n",
    "\n",
    "# ─── Sheet 2: Samenvatting per user ──────────────────────────────────────────\n",
