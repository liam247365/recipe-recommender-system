    ").reset_index()\n",
    "\n",
    "s_headers = ['user_id', 'profiel', 'aantal_ingredienten', 'categorieen']\n",
    "ws2.append(s_headers)\n",
    "for col_idx, h in enumerate(s_headers, 1):\n",
    "    cell = ws2.cell(row=1, column=col_idx)\n",
